import pygame
import sys

pygame.init()

# SCREEN 
WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("TDS Prototype")

clock = pygame.time.Clock()

# MAIN LOOP
running = True
while running:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

    screen.fill((30, 30, 30))  # background color

    pygame.display.flip()
    clock.tick(60)

pygame.quit()
sys.exit()
